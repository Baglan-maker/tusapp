# ---- Local Postgres (docker-compose) ----
# For the API running on the host against the docker DB:
DATABASE_URL=postgresql+psycopg://tus:tus@localhost:5432/tus

# ---- Supabase (Postgres + Auth + Storage) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Speech-to-text ----
# Russian -> Groq whisper-large-v3; Kazakh -> ElevenLabs Scribe
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2

# ---- LLM (Anthropic) ----
# Extraction stays on Haiku. Interpretation model is swappable so we can
# eval Haiku vs Sonnet on the golden set (e.g. claude-sonnet-5).
ANTHROPIC_API_KEY=
EXTRACT_MODEL=claude-haiku-4-5
INTERPRET_MODEL=claude-haiku-4-5

# ---- Embeddings (OpenAI text-embedding-3-small) ----
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
