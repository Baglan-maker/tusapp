# Copy to .env — EXPO_PUBLIC_* vars are inlined into the client bundle,
# so ONLY public values belong here (never the Supabase service key).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Local API. On a physical device use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:8000
